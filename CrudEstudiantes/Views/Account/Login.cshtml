@model CrudEstudiantes.ViewModels.LoginViewModel

@{
    ViewData["Title"] = "Login";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-5">
        <div class="card shadow">
            <div class="card-header text-center">
                <h3 id="login-title">Iniciar Sesión</h3>
            </div>
            <div class="card-body">
                <form asp-action="Login" method="post" id="login-form">
                    @Html.AntiForgeryToken()

                    <div class="mb-3">
                        <label asp-for="Username" class="form-label">Usuario</label>
                        <input asp-for="Username" id="username" class="form-control" />
                        <span asp-validation-for="Username" class="text-danger" id="username-error"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Password" class="form-label">Contraseña</label>
                        <input asp-for="Password" id="password" type="password" class="form-control" />
                        <span asp-validation-for="Password" class="text-danger" id="password-error"></span>
                    </div>

                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger" id="login-error">
                            @ViewBag.Error
                        </div>
                    }

                    <button type="submit" id="login-button" class="btn btn-primary w-100">
                        Entrar
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}